generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CreditCard {
  id         String          @id @default(cuid())
  name       String          @unique
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  statements CardStatement[]
}

model CardStatement {
  id               String            @id @default(cuid())
  creditCardId     String
  creditCard       CreditCard        @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  rawStatementDate String
  statementDate    DateTime
  rawDueDate       String
  dueDate          DateTime
  totalPayable     Decimal           @db.Decimal(12, 2)
  amountDue        Decimal           @db.Decimal(12, 2)
  paidAmount       Decimal           @default(0) @db.Decimal(12, 2)
  importedAt       DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  transactions     CardTransaction[]

  @@unique([creditCardId, statementDate])
  @@index([statementDate])
  @@index([dueDate])
}

model CardTransaction {
  id            String          @id @default(cuid())
  statementId   String
  statement     CardStatement   @relation(fields: [statementId], references: [id], onDelete: Cascade)
  postedOnLabel String
  postedOnMonth Int
  postedOnDay   Int
  description   String
  amount        Decimal         @db.Decimal(12, 2)
  type          TransactionType
  position      Int
  createdAt     DateTime        @default(now())

  @@unique([statementId, position])
  @@index([statementId, postedOnMonth, postedOnDay])
}

enum TransactionType {
  debit
  credit
}
